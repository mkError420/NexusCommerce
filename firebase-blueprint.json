{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available for purchase in the store.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the product." },
        "description": { "type": "string", "description": "A detailed description of the product." },
        "price": { "type": "number", "description": "The price of the product." },
        "category": { "type": "string", "description": "The category the product belongs to." },
        "image": { "type": "string", "description": "URL to the product image." },
        "rating": { "type": "number", "description": "Average rating of the product." },
        "reviews": { "type": "integer", "description": "Number of reviews for the product." },
        "stock": { "type": "integer", "description": "Current stock level." }
      },
      "required": ["name", "price", "category", "image", "stock"]
    },
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "description": "URL to the user's profile photo." },
        "role": { "type": "string", "enum": ["admin", "customer"], "description": "The user's role." }
      },
      "required": ["email", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer's order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who placed the order." },
        "items": { 
          "type": "array", 
          "items": { "type": "object" },
          "description": "List of items in the order." 
        },
        "total": { "type": "number", "description": "The total amount of the order." },
        "status": { "type": "string", "enum": ["pending", "shipped", "delivered"], "description": "Order status." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the order was placed." }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products available in the store."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders."
    }
  }
}
